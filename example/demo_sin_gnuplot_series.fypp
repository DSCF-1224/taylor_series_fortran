#:mute

    #:include 'common.fypp'

    #:set FILE_NAME = _FILE_.replace('_gnuplot', '').replace('.fypp', '') + '_' + REAL_KIND

#:endmute
reset session

set terminal svg noenhanced
set output '${FILE_NAME}$.svg'

set title 'sin(x) (using ${REAL_KIND}$)'

set xlabel 'x'

set ylabel 'taylor_series_sin(x)'
set yrange [-2:2]

set key outside right center

plot \
    sin(x) \
        linecolor black \
        title 'intrinsic' , \
    for [i = 0:10] \
        '${FILE_NAME.replace('_series', '')}$.dat' \
            using 2:3 \
            every 1:2:i:0:i:(${MAXVAL_DEGREE}$ - 1) \
            with points linecolor black pointsize 0.5 \
            title sprintf('%d', i)
